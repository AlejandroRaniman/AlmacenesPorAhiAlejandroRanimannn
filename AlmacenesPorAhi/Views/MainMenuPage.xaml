<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AlmacenesPorAhi.ViewModels"
             x:Class="AlmacenesPorAhi.Views.MainMenuPage"
             Title="Menú Principal"
             BackgroundColor="#F4F6F4">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="30" VerticalOptions="Center">
            
            <Image Source="almacenapp_logo.svg" HeightRequest="120" HorizontalOptions="Center" Margin="0,0,0,20"/>
            
            <Label Text="Sistema de Administración" 
                   FontSize="24" 
                   FontAttributes="Bold" 
                   TextColor="#2D4236" 
                   HorizontalOptions="Center"/>

            <Button Text="Gestión de Inventario (Productos)"
                    Command="{Binding IrAInventarioCommand}"
                    HeightRequest="55"
                    BackgroundColor="#4A6B56"
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    Margin="0,10,0,0"/>

            <Button Text="Gestión de Clientes"
                    Command="{Binding IrAClientesCommand}"
                    HeightRequest="55"
                    BackgroundColor="#2D4236"
                    TextColor="White"
                    FontSize="16"
                    FontAttributes="Bold"
                    CornerRadius="8"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>