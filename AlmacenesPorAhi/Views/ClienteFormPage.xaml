<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AlmacenesPorAhi.Views.ClienteFormPage"
             Title="Formulario de Cliente"
             BackgroundColor="White">

    <ScrollView>
        <VerticalStackLayout Spacing="14" Padding="20">

            <Label Text="Información del Cliente" FontSize="20" FontAttributes="Bold" TextColor="#2D4236" Margin="0,0,0,10"/>

            <Label Text="RUT *" FontAttributes="Bold" FontSize="14"/>
            <Entry Text="{Binding Rut}" Placeholder="Ej: 12.345.678-9"/>

            <Label Text="Nombre *" FontAttributes="Bold" FontSize="14"/>
            <Entry Text="{Binding Nombre}" Placeholder="Nombre del cliente"/>

            <Label Text="Apellido Paterno *" FontAttributes="Bold" FontSize="14"/>
            <Entry Text="{Binding ApellidoPaterno}" Placeholder="Apellido paterno"/>

            <Label Text="Apellido Materno *" FontAttributes="Bold" FontSize="14"/>
            <Entry Text="{Binding ApellidoMaterno}" Placeholder="Apellido materno"/>

            <Label Text="Correo Electrónico *" FontAttributes="Bold" FontSize="14"/>
            <Entry Text="{Binding Email}" Keyboard="Email" Placeholder="ejemplo@correo.com"/>

            <Label Text="Teléfono Móvil *" FontAttributes="Bold" FontSize="14"/>
            <Entry Text="{Binding Telefono}" Keyboard="Telephone" Placeholder="Ej: +56912345678"/>

            <Label Text="Dirección Particular *" FontAttributes="Bold" FontSize="14"/>
            <Editor Text="{Binding Direccion}" Placeholder="Calle, Número, Ciudad" AutoSize="TextChanges" HeightRequest="70"/>

            <Label Text="Estado de Cuenta *" FontAttributes="Bold" FontSize="14"/>
            <Picker SelectedItem="{Binding Estado}">
                <Picker.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>Activo</x:String>
                        <x:String>Inactivo</x:String>
                    </x:Array>
                </Picker.ItemsSource>
            </Picker>

            <Grid ColumnDefinitions="*, *" ColumnSpacing="15" Margin="0,20,0,0">
                <Button Grid.Column="0" Text="Guardar" Command="{Binding SaveCommand}" BackgroundColor="#2D4236" TextColor="White" FontAttributes="Bold" HeightRequest="48"/>
                <Button Grid.Column="1" Text="Cancelar" Command="{Binding CancelCommand}" BackgroundColor="#7F8C8D" TextColor="White" FontAttributes="Bold" HeightRequest="48"/>
            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>